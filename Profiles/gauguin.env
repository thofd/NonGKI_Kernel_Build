CONFIG_ENV=Profiles/gauguin.env

DEVICE_NAME=redmi note9pro
DEVICE_CODENAME=gauguin

CUSTOM_CMDS:CLANG_TRIPLE=aarch64-linux-gnu-
EXTRA_CMDS:LD=ld.lld

KERNEL_SOURCE=https://github.com/thofd/neko_kernel_xiaomi_gauguin.git
KERNEL_BRANCH=main
CLANG_SOURCE=https://github.com/LineageOS/android_prebuilts_clang_kernel_linux-x86_clang-r416183b.git
CLANG_BRANCH=lineage-20.0

GCC_64_SOURCE=https://github.com/JackA1ltman/Google-GCC-Android-4.9.git
GCC_64_BRANCH=aarch64
GCC_32_SOURCE=https://github.com/JackA1ltman/Google-GCC-Android-4.9.git
GCC_32_BRANCH=arm32

DEFCONFIG_SOURCE=
DEFCONFIG_NAME=vendor/gauguin_user_defconfig

KERNEL_VERSION=4.19

SUSFS_ENABLE=true
SUSFS_FIXED=true

BOOT_SOURCE=https://github.com/JackA1ltman/Kernel_Extra/raw/refs/heads/main/Evox_Mix2s_A15/source_imgs/boot.img

ROM_TEXT=gauguin
